# Dev only: куда проксировать /api из vite dev server (см. vite.config.ts).
# По умолчанию указывает на gateway, запущенный локально.
VITE_GATEWAY_PROXY_TARGET=http://localhost:8082

# Prod only (используется nginx.conf.template в контейнере): адрес gateway
# внутри docker-сети, куда nginx проксирует /api/.
GATEWAY_UPSTREAM=gateway:8082
